#include <stdio.h>
int reverse_recursive(int num, int accumulated) {
    if (num == 0) {
        return accumulated;
    }
    int last_digit = num % 10;
    int new_accumulated = (accumulated * 10) + last_digit;
    return reverse_recursive(num / 10, new_accumulated);
}
int main() {
    int number;
    printf("Enter an integer: ");
    if (scanf("%d", &number) != 1) {
        printf("Invalid input.\n");
        return 1;
    }
    int reversed = reverse_recursive(number, 0);
    printf("Reversed number: %d\n", reversed);
    return 0;
}

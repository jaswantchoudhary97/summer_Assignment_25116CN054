#include <stdio.h>
#include <math.h>
int isArmstrong(int num);
int main() {
    int number;
    printf("Enter an integer: ");
    scanf("%d", &number);
    if (isArmstrong(number)) {
        printf("%d is an Armstrong number.\n", number);
    } else {
        printf("%d is not an Armstrong number.\n", number);
    }
    return 0;
}
int isArmstrong(int num) {
    int temp, remainder, digits = 0, sum = 0;
    temp = num;
    while (temp != 0) {
        digits++;
        temp /= 10;
    }
    temp = num;
    while (temp != 0) {
        remainder = temp % 10;
        sum += (int)round(pow(remainder, digits));
        temp /= 10;
    }
    return (sum == num);
}

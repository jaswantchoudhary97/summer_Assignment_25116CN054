#include <stdio.h>
#include <string.h>
int main() {
    char str[100];
    int left = 0;
    int right;
    int isPalindrome = 1;
    printf("Enter a string: ");
    scanf("%[^\n]", str);
    right = strlen(str) - 1;
    while (left < right) {
        if (str[left] != str[right]) {
            isPalindrome = 0;
            break;
        }
        left++;
        right--;
    }
    if (isPalindrome) {
        printf("\"%s\" is a palindrome string.\n", str);
    } else {
        printf("\"%s\" is not a palindrome string.\n", str);
    }
    return 0;
}

#include <stdio.h>
double calculate_power(double base, int exp) {
    double result = 1.0;
    long long absolute_exp = exp;
    if (absolute_exp < 0) {
        absolute_exp = -absolute_exp;
        base = 1.0 / base;
    }
    while (absolute_exp > 0) {
        if (absolute_exp % 2 == 1) {
            result *= base;
        }
        base *= base;
        absolute_exp /= 2;
    }
    return result;
}
int main() {
    double base;
    int exp;
    printf("Enter base (x): ");
    if (scanf("%lf", &base) != 1) {
        printf("Invalid base input.\n");
        return 1;
    }
    printf("Enter integer exponent (n): ");
    if (scanf("%d", &exp) != 1) {
        printf("Invalid exponent input.\n");
        return 1;
    }
    if (base == 0.0 && exp == 0) {
        printf("0^0 is mathematically undefined or traditionally evaluates to 1.\n");
    }
    double ans = calculate_power(base, exp);
    printf("%.4f^%d = %.6f\n", base, exp, ans);
    return 0;
}

#include <stdio.h>
unsigned int countSetBits(int n) {
    unsigned int count = 0;
    while (n > 0) {
        n &= (n - 1); 
        count++;
    }
    return count;
}
int main() {
    int num;
    printf("Enter an integer: ");
    if (scanf("%d", &num) != 1) {
        printf("Invalid input.\n");
        return 1;
    }
    printf("Number of set bits in %d is: %u\n", num, countSetBits(num));    
    return 0;
}

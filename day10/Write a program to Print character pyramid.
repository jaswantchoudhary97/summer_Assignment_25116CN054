#include <stdio.h>
int main() {
    int rows, i, j, space;
    char ch = 'A';
    printf("Enter the number of rows (1-26): ");
    scanf("%d", &rows);
    for (i = 1; i <= rows; i++) {
        for (space = 1; space <= rows - i; space++) {
            printf(" ");
        }
        for (j = 1; j <= i; j++) {
            printf("%c ", ch);
        }
        printf("\n");
        ch++;
    }
    return 0;
}

#include <stdio.h>
#include <string.h>
void compressString(const char *input, char *output) {
    int i = 0;
    int j = 0;
    int len = strlen(input);
    if (len == 0) {
        output[0] = '\0';
        return;
    }
    while (i < len) {
        int count = 1;
        while (i + 1 < len && input[i] == input[i + 1]) {
            count++;
            i++;
        }
        output[j++] = input[i];
        int bytesWritten = sprintf(&output[j], "%d", count);
        j += bytesWritten;
        i++;
    }
    output[j] = '\0';
}
int main() {
    char inputString[] = "AAAABBBCCDAA";
    char compressedString[2 * sizeof(inputString)];
    printf("Original String: %s\n", inputString);
    compressString(inputString, compressedString);
    printf("Compressed String: %s\n", compressedString);
    return 0;
}
